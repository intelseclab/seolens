{
  "manifest_version": 3,
  "name": "SEO Lens — Sayfa Analiz Aracı",
  "version": "2.0.0",
  "description": "Aktif sayfanın SEO sağlığını anında analiz edin: meta etiketler, başlık hiyerarşisi, Core Web Vitals, linkler, şema ve görseller.",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "SEO Lens'i Aç",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
